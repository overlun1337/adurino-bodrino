#include <Keypad.h>


const byte ROWS = 4; 
const byte COLS = 4; 
const byte buzzer = 10;

char keys[ROWS][COLS] = {
  {'1','2','3','A'},
  {'4','5','6','B'},
  {'7','8','9','C'},
  {'*','0','#','D'}
};

byte rowPins[ROWS] = {9, 8, 7, 6}; 
byte colPins[COLS] = {5, 4, 3, 2}; 

Keypad myKeypad = Keypad(makeKeymap(keys), rowPins, colPins, ROWS, COLS);


String currentPassword = "1337"; 
String inputBuffer = "";
bool isChangeMode = false;

void setup() {
  pinMode(buzzer, OUTPUT);
  Serial.begin(9600);
  Serial.println("hello world");
  Serial.println("Enter password or press '*' to change it.");
}

void loop() {
  char key = myKeypad.getKey();

  if (key) {
    playTone(1000, 100); 
    

    if (key == '*') {
      isChangeMode = true;
      inputBuffer = "";
      Serial.println("\n[MODE] Changing password. Enter NEW code then press '#':");
      return;
    }

    
    if (key == '#') {
      if (isChangeMode) {
        currentPassword = inputBuffer;
        isChangeMode = false;
        Serial.println("\n[SUCCESS] Password updated!");
        successBeep();
      } else {
        checkPassword();
      }
      inputBuffer = ""; 
    } 
    
    else {
      inputBuffer += key;
      Serial.print("*"); 
    }
  }
}


void checkPassword() {
  if (inputBuffer == currentPassword) {
    Serial.println("\n[ACCESS GRANTED] Welcome!");
    successBeep();
  } else {
    Serial.println("\n[ACCESS DENIED] Wrong password!");
    errorBeep();
  }
}


void playTone(int freq, int duration) {
  tone(buzzer, freq, duration);
}

void successBeep() {
  tone(buzzer, 1500, 200);
  delay(250);
  tone(buzzer, 2000, 200);
}

void errorBeep() {
  tone(buzzer, 400, 500);
}
